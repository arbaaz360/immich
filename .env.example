# Copy this file to .env next to docker-compose.yml when restoring.
# Do not commit the real .env file.

IMMICH_DB_PASSWORD=postgres

# Immich API keys used only by the folder album creator containers.
IMMICH_API_KEY_ARBAAZ=replace_me
IMMICH_API_KEY_REALFIRE2023=replace_me
IMMICH_API_KEY_FIREREAL06=replace_me

# Optional for scripts/reverse_face_search.py thumbnail proxy.
# You can also create scripts/immich_api_keys.local.txt with one key per line.
IMMICH_API_KEYS=replace_me

# Optional for profile picture picker VLM review.
# Leave LM_STUDIO_MODEL empty to use the fast local scoring only.
LM_STUDIO_MODEL=
LM_STUDIO_URL=http://host.docker.internal:1234/v1/chat/completions
